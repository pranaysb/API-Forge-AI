# Database URL
# For production (e.g. Supabase): postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require
# For local dev fallback: sqlite:///./apiforge.db
DATABASE_URL=sqlite:///./apiforge.db

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# LLM Providers (Pick at least one, usually Groq is the default)
GROQ_API_KEY=gsk_...
# GROQ_API_KEY_1=...  # Optional: For failover
# GROQ_API_KEY_2=...  # Optional: For failover
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Sandbox Provider (For code integrity testing)
E2B_API_KEY=e2b_...
